# Secrets for the google-health-* Edge Functions. Set these with:
#   supabase secrets set --env-file supabase/functions/.env
# Never commit the real .env file - only this .env.example template.
#
# SUPABASE_URL, SUPABASE_ANON_KEY and SUPABASE_SERVICE_ROLE_KEY are injected
# automatically by the Supabase Edge Runtime - do not set them here.

# From Google Cloud Console > APIs & Services > Credentials (OAuth 2.0 Client ID)
GOOGLE_HEALTH_CLIENT_ID=
GOOGLE_HEALTH_CLIENT_SECRET=

# Must exactly match the deployed URL of google-health-callback AND the
# "Authorized redirect URI" registered for the OAuth client in Google Cloud
# Console, e.g. https://<project-ref>.supabase.co/functions/v1/google-health-callback
GOOGLE_HEALTH_REDIRECT_URI=

# Where google-health-callback redirects the browser back to after linking,
# e.g. http://localhost:5173 in dev or your deployed app URL in production.
APP_URL=
